---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'UX検定基礎 練習問題集' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | UX検定基礎 練習問題集</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-50 min-h-screen font-sans">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-3xl mx-auto px-4 py-3 flex items-center gap-3">
        <a href={import.meta.env.BASE_URL.replace(/\/?$/, '/')} class="flex items-center gap-2 text-slate-800 hover:text-indigo-600 transition-colors">
          <span class="text-lg font-bold">UX検定基礎</span>
          <span class="text-slate-400 text-sm">練習問題集</span>
        </a>
      </div>
    </header>
    <main class="max-w-3xl mx-auto px-4 py-8">
      <slot />
    </main>
  </body>
</html>
