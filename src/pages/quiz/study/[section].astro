---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SECTIONS, QUESTIONS } from '../../../data/questions';

export function getStaticPaths() {
  return SECTIONS.map((section) => ({
    params: { section: section.id },
  }));
}

const { section: sectionId } = Astro.params;
const section = SECTIONS.find((s) => s.id === sectionId)!;
const questions = QUESTIONS.filter((q) => q.sectionId === sectionId);
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title={`学習 - ${section.label}`}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-3">
      <a href={`${BASE}`} class="text-slate-400 hover:text-indigo-600 transition-colors text-sm">← ホーム</a>
      <span class="text-slate-300">/</span>
      <span class="text-sm text-slate-500">{section.label}</span>
    </div>

    <div class="space-y-1">
      <h1 class="text-2xl font-bold text-slate-800">{section.label}</h1>
      <p class="text-slate-500 text-sm">{section.description}</p>
    </div>

    <div class="flex items-center justify-between">
      <p class="text-sm text-slate-400">{questions.length}問を学習モードで表示中</p>
      <a
        href={`${BASE}quiz/${sectionId}/`}
        class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl px-5 py-2.5 transition-colors"
      >
        練習する →
      </a>
    </div>

    <!-- Question list -->
    <div class="space-y-5">
      {questions.map((q, idx) => (
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <!-- Question -->
          <div class="p-5 space-y-4">
            <div class="flex gap-3">
              <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold">
                {idx + 1}
              </span>
              <p class="text-slate-800 font-medium leading-relaxed pt-0.5">{q.question}</p>
            </div>

            <!-- Choices -->
            <div class="space-y-2 pl-10">
              {q.choices.map((choice, ci) => (
                <div class={`flex gap-2.5 items-start rounded-lg px-4 py-2.5 text-sm ${ci === q.correctIndex ? 'bg-green-50 border border-green-300' : 'bg-slate-50 border border-transparent'}`}>
                  <span class={`shrink-0 font-bold text-xs mt-0.5 ${ci === q.correctIndex ? 'text-green-600' : 'text-slate-400'}`}>
                    {ci === q.correctIndex ? '✓' : `${ci + 1}.`}
                  </span>
                  <span class={ci === q.correctIndex ? 'text-green-800 font-semibold' : 'text-slate-500'}>{choice}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Explanation -->
          <div class="border-t border-slate-100 bg-slate-50 px-5 py-4 space-y-3">
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">解説</p>
              <p class="text-sm text-slate-700 leading-relaxed">{q.explanation}</p>
            </div>
            {q.tip && (
              <div class="border-t border-slate-200 pt-3">
                <p class="text-xs font-semibold text-amber-600 uppercase tracking-wider mb-1.5">Point</p>
                <p class="text-sm text-slate-700 leading-relaxed">{q.tip}</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom actions -->
    <div class="flex gap-3 pt-2">
      <a href={`${BASE}`} class="flex-1 text-center border border-slate-200 text-slate-600 hover:border-indigo-300 hover:text-indigo-700 font-semibold rounded-xl px-4 py-3 transition-all text-sm">
        ← ホームへ
      </a>
      <a href={`${BASE}quiz/${sectionId}/`} class="flex-1 text-center bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl px-4 py-3 transition-colors text-sm">
        練習する →
      </a>
    </div>
  </div>
</BaseLayout>
