---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QUESTIONS } from '../../data/questions';

const allQuestionsJson = JSON.stringify(QUESTIONS);
const homeUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="弱点モード">
  <script is:inline define:vars={{ allQuestionsJson, homeUrl }}>
    window.__ALL_QUESTIONS__ = JSON.parse(allQuestionsJson);
    window.__QUIZ_HOME_URL__ = homeUrl;
  </script>

  <div class="mb-6">
    <div class="flex items-center justify-between text-sm mb-2">
      <span id="section-label" class="font-semibold text-slate-700">弱点モード</span>
      <span id="score-display" class="text-slate-500">スコア: 0 / 0</span>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex-1 bg-slate-200 rounded-full h-2.5">
        <div id="progress-bar" class="bg-amber-500 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
      <span id="progress-label" class="text-sm text-slate-400 shrink-0 w-14 text-right">0 / 0</span>
    </div>
  </div>

  <div id="quiz-container" class="min-h-64"></div>
</BaseLayout>

<script>
  import { getWeakIds } from '../../utils/storage';
  import { initQuiz } from '../../scripts/quiz-engine';

  const ids = new Set(getWeakIds(30));
  const all: typeof window.__QUIZ_QUESTIONS__ = window.__ALL_QUESTIONS__;
  window.__QUIZ_QUESTIONS__ = ids.size > 0
    ? all.filter((q) => ids.has(q.id))
    : [];
  window.__QUIZ_SECTION_LABEL__ = '弱点モード';
  initQuiz();
</script>
